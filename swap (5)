from pathlib import Path

html = r"""
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>PhotoSwap Prototype</title>
<style>
body{font-family:Arial,sans-serif;margin:0;background:#f4f4f4}
.header{background:#222;color:white;padding:14px;text-align:center;font-size:22px}
.screen{display:none;padding:16px}
.active{display:block}
.card{background:white;border-radius:12px;padding:12px;margin:12px 0;box-shadow:0 1px 4px rgba(0,0,0,.15)}
.photo{width:100%;height:220px;object-fit:cover;border-radius:10px}
.nav{position:fixed;bottom:0;left:0;right:0;background:white;display:flex;border-top:1px solid #ddd}
.nav button{flex:1;padding:14px;border:none;background:white}
.stat{font-size:14px;color:#555}
.map{height:220px;background:#ddd;border-radius:10px;display:flex;align-items:center;justify-content:center}
</style>
</head>
<body>
<div class="header">PhotoSwap Prototype</div>

<div id="home" class="screen active">
<h2>Incoming Photo</h2>
<div class="card">
<img class="photo" src="https://picsum.photos/600/400?random=12">
<p><b>Origin:</b> London, UK</p>
<p class="stat">Shared 247 times • 18 countries</p>
<button onclick="show('journey')">View Journey</button>
</div>
</div>

<div id="upload" class="screen">
<h2>Upload Photo</h2>
<div class="card">
<p>Choose a photo and release it into the world.</p>
<input type="file">
<br><br>
<button onclick="alert('Demo: Photo released to the world!')">Send Photo</button>
</div>
</div>

<div id="journey" class="screen">
<h2>Photo Passport</h2>
<div class="card">
<div class="map">🌍 UK → France → Germany → Japan → Australia</div>
<p><b>Total Shares:</b> 247</p>
<p><b>Distance Travelled:</b> 91,000 km</p>
</div>
</div>

<div id="profile" class="screen">
<h2>Your Profile</h2>
<div class="card">
<p><b>Photos Sent:</b> 12</p>
<p><b>Photos Received:</b> 34</p>
<p><b>Most Traveled Photo:</b> 42 countries</p>
</div>
</div>

<div class="nav">
<button onclick="show('home')">Home</button>
<button onclick="show('upload')">Upload</button>
<button onclick="show('journey')">Journey</button>
<button onclick="show('profile')">Profile</button>
</div>

<script>
function show(id){
 document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
 document.getElementById(id).classList.add('active');
}
</script>
</body>
</html>
"""
path = "/mnt/data/PhotoSwap_Prototype.html"
Path(path).write_text(html, encoding="utf-8")
print(path)
